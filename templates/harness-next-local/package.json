{
  "name": "ai-harness-next-local-project",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --port 3200",
    "build": "next build",
    "typecheck": "tsc --noEmit",
    "context:check": "node scripts/context-check.mjs",
    "lint:arch": "node scripts/harness-lint.mjs",
    "test:structure": "node --test tests/harness-structure.test.mjs",
    "test:ui-harness": "node --test tests/ui-harness.test.mjs",
    "test:domain": "node --import tsx --test tests/example-contract.test.ts",
    "template:doctor": "node scripts/template-doctor.mjs",
    "verify:harness": "npm run typecheck && npm run context:check && npm run lint:arch && npm run test:structure && npm run test:ui-harness && npm run test:domain && npm run template:doctor",
    "verify": "npm run verify:harness"
  },
  "dependencies": {
    "next": "^15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "tsx": "^4.22.4",
    "typescript": "^5.7.3"
  }
}

